{
  "name": "bridge-creative-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Bridge Creative Engine - Standalone, client-side AIDA video generator powered by Gemini",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/copy-ffmpeg-core.mjs",
    "build:vite": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p worker/tsconfig.json",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "worker:dev": "cd worker && wrangler dev --port 8787",
    "worker:deploy": "cd worker && wrangler deploy",
    "worker:typecheck": "tsc --noEmit -p worker/tsconfig.json",
    "postinstall": "node scripts/copy-ffmpeg-core.mjs"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "idb": "^8.0.0",
    "immer": "^10.1.1",
    "jszip": "^3.10.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@ffmpeg/core": "^0.12.6",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.4.0",
    "@typescript-eslint/parser": "^8.4.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.10.0",
    "eslint-plugin-react-hooks": "^5.0.0-rc-1",
    "eslint-plugin-react-refresh": "^0.4.11",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.9.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.4.0",
    "vite": "^5.4.5",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
